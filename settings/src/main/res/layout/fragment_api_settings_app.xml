<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:divider="@drawable/spacer_large"
            android:showDividers="middle">

    <!-- Language Section -->
    <TextView
        style="@style/TextAppearance.Material3.TitleMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="语言"
        android:layout_marginBottom="8dp"/>
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/language_spinner_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <AutoCompleteTextView
            android:id="@+id/language_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:text="简体中文"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Performance and Display Settings -->
    <TextView
        style="@style/TextAppearance.Material3.TitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="性能与显示设置"
        android:layout_marginTop="24dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">
        <TextView
            style="@style/TextAppearance.Material3.BodyLarge"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="聊天列表每次加载条数"/>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/chat_load_count_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">
        <TextView
            style="@style/TextAppearance.Material3.BodyLarge"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="聊天界面初始加载条数"/>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/initial_load_count_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/background_service_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="后台消息接收服务"
        android:layout_marginTop="16dp"
        app:thumbIcon="@drawable/ic_brain_24"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/hint_background_green"
        android:padding="8dp"
        android:layout_marginTop="4dp"
        android:text="开启后,即使应用在后台也能接收AI消息并显示通知。关闭可节省电量,但可能无法及时收到消息。"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"/>

    <!-- Storage Optimization -->
    <TextView
        style="@style/TextAppearance.Material3.TitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="存储空间"
        android:layout_marginTop="24dp"/>
    <Button
        android:id="@+id/button_storage_avatar"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="start|center_vertical"
        android:textAllCaps="false"
        android:text="头像：正在统计..." />

    <Button
        android:id="@+id/button_storage_chat_image"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="start|center_vertical"
        android:textAllCaps="false"
        android:text="聊天图片：正在统计..." />

    <Button
        android:id="@+id/button_storage_album"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="start|center_vertical"
        android:textAllCaps="false"
        android:text="相册：正在统计..." />

    <Button
        android:id="@+id/button_storage_chat_record"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="start|center_vertical"
        android:textAllCaps="false"
        android:text="聊天记录：正在统计..." />

    <Button
        android:id="@+id/button_storage_vector"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="start|center_vertical"
        android:textAllCaps="false"
        android:text="向量数据：正在统计..." />

    <Button
        android:id="@+id/button_storage_other"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="start|center_vertical"
        android:textAllCaps="false"
        android:text="其他：正在统计..." />

    <Button
        android:id="@+id/button_storage_total"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="start|center_vertical"
        android:textAllCaps="false"
        android:text="总计：正在统计..." />
    <Button
        android:id="@+id/button_clear_tts_cache"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="清理未引用语音缓存" />

    <Button
        android:id="@+id/button_compress_images"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="一键压缩本地图片" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/hint_background_green"
        android:padding="8dp"
        android:layout_marginTop="4dp"
        android:text="此功能会将您所有本地上传的图片(如头像、表情包、聊天图片、头像框、组件图等)压缩为JPEG格式,以大幅减小数据体积。\n警告:这是一个有损压缩且不可逆的操作,会轻微降低图片质量。建议操作前先备份数据。"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"/>

    <!-- Data Management Buttons -->
    <Button
        android:id="@+id/button_export_data"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="导出数据"/>
    <Button
        android:id="@+id/button_import_data"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="导入备份文件"/>
    <Button
        android:id="@+id/button_clear_redundant_data"
        style="@style/Widget.Material3.Button.OutlinedButton"
        app:strokeColor="?attr/colorError"
        android:textColor="?attr/colorError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="清理冗余数据"/>

    <!-- Danger Zone -->
    <Button
        android:id="@+id/button_delete_worldbook"
        style="@style/Widget.Material3.Button.OutlinedButton"
        app:strokeColor="?attr/colorError"
        android:textColor="?attr/colorError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="删除世界书"/>
    <Button
        android:id="@+id/button_advanced_data_cleaning"
        style="@style/Widget.Material3.Button.OutlinedButton"
        app:strokeColor="?attr/colorError"
        android:textColor="?attr/colorError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="高级数据清理"/>
    <Button
        android:id="@+id/button_data_check_and_repair"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="数据检查与修复"/>

    <!-- Permission Section -->
    <TextView
        style="@style/TextAppearance.Material3.TitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="权限"
        android:layout_marginTop="24dp"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/button_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:strokeColor="?attr/colorPrimary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_rounded_gray"
                android:contentDescription="权限管理"
                android:padding="8dp"
                android:src="@drawable/ic_add_alert"
                android:tint="?attr/colorPrimary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="权限管理"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="管理来电通知、全屏来电和悬浮窗权限，拒绝后可随时重新开启"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="查看"
                android:src="@drawable/ic_chevron_right_24"
                android:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- About Section -->
    <TextView
        style="@style/TextAppearance.Material3.TitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="关于"
        android:layout_marginTop="24dp"/>
    
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/button_feature_overview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:strokeColor="?attr/colorPrimary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_rounded_gray"
                android:contentDescription="功能一览"
                android:padding="8dp"
                android:src="@drawable/ic_auto_awesome_24"
                android:tint="?attr/colorPrimary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="功能一览"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="看看小手机已经准备了哪些桌面应用、AI能力和数据工具"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="查看"
                android:src="@drawable/ic_chevron_right_24"
                android:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/button_about"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="关于小手机"
        app:icon="@drawable/ic_info_24"/>
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/hint_background"
        android:padding="8dp"
        android:layout_marginTop="4dp"
        android:text="查看应用信息、隐私政策和开源许可证"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>