<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/importToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:title="导入课表"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/importToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="仅支持粘贴学校 HTML 课表源码。小手机会先生成识别预览，确认后才会写入正式课程。"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/importRawTextInput"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:background="@android:drawable/edit_text"
                android:gravity="top|start"
                android:hint="请粘贴包含 table id为 timetable 的 HTML 课表源码"
                android:inputType="textMultiLine"
                android:padding="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/parsePreviewButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="解析预览" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="请确认识别结果"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:id="@+id/previewWeekdayScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fillViewport="true"
                        android:scrollbars="none"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/previewWeekdayToggleGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:checkedButton="@id/previewMondayButton"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/previewMondayButton"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:text="周一" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/previewTuesdayButton"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:text="周二" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/previewWednesdayButton"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:text="周三" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/previewThursdayButton"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:text="周四" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/previewFridayButton"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:text="周五" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/previewSaturdayButton"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:text="周六" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/previewSundayButton"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:text="周日" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </HorizontalScrollView>

                    <TextView
                        android:id="@+id/importPreviewText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/confirmImportButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="确认导入" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
