<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/assignmentEditorToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:title="作业编辑"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/assignmentEditorToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="独立作业编辑页"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/assignmentTitleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="作业标题"
                android:inputType="text" />

            <EditText
                android:id="@+id/assignmentContentInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="作业内容，可留空"
                android:inputType="textMultiLine"
                android:maxLines="4" />

            <EditText
                android:id="@+id/assignmentPriorityInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="优先级，1-5"
                android:inputType="number" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveAssignmentButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="保存作业" />

            <!-- 仅在编辑已有作业时可见，用于在 TODO ↔ DONE 之间切换完成状态 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/toggleAssignmentStatusButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="标记完成"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
