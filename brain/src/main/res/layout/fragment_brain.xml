<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- 悬浮球 -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/fabBrain"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="56dp"
        android:background="?attr/colorPrimary"
        android:contentDescription="Brain"
        android:padding="10dp"
        android:src="@drawable/ic_brain_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:tint="?attr/colorOnPrimary" />

    <!-- 展开后的日志窗口 -->
    <!-- 修改约束：屏幕上方水平居中 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewBrain"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:padding="12dp">

            <TextView
                android:id="@+id/textViewTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="大脑活动日志"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 后台任务统计条目 -->
            <include
                android:id="@+id/layoutBackgroundTaskSummary"
                layout="@layout/brain_item_background_task_summary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/textViewTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <include
                android:id="@+id/layoutAutoPlanSummary"
                layout="@layout/brain_item_auto_plan_summary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/layoutBackgroundTaskSummary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageButton
                android:id="@+id/buttonCancelAllTasks"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_close_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Cancel all background tasks"
                app:layout_constraintEnd_toStartOf="@+id/buttonMarkAllRead"
                app:layout_constraintTop_toTopOf="@+id/textViewTitle"
                app:layout_constraintBottom_toBottomOf="@+id/textViewTitle"/>

            <ImageButton
                android:id="@+id/buttonMarkAllRead"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_visibility_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Mark all as read"
                app:layout_constraintEnd_toStartOf="@+id/buttonClearAll"
                app:layout_constraintTop_toTopOf="@+id/textViewTitle"
                app:layout_constraintBottom_toBottomOf="@+id/textViewTitle"/>

            <ImageButton
                android:id="@+id/buttonClearAll"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_delete_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear all"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/textViewTitle"
                app:layout_constraintBottom_toBottomOf="@+id/textViewTitle"/>


            <!-- 限制 RecyclerView 高度 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAiActivities"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:minHeight="100dp"
                app:layout_constraintTop_toBottomOf="@id/layoutAutoPlanSummary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintHeight_default="wrap"
                app:layout_constraintHeight_max="300dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/brain_item_ai_activity" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>