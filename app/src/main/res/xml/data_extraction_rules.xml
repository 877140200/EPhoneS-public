<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- 排除激活状态：license_prefs 不参与云端备份。
             否则换设备后激活状态随云端还原，绕过 Worker 账本，破坏“一设备一码”。 -->
        <exclude domain="sharedpref" path="license_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- 设备直传（如换机助手）同样排除激活状态，理由同上。 -->
        <exclude domain="sharedpref" path="license_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>