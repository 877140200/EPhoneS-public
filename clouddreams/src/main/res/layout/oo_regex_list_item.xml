<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="2dp"
    android:gravity="center_vertical">

    <!-- 规则名称 -->
    <TextView
        android:id="@+id/rule_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- 按钮容器 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- 启用/禁用按钮 -->
        <ImageButton
            android:id="@+id/toggle_enable"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/baseline_toggle_on_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="启用/禁用"
            android:layout_marginStart="4dp" />

        <!-- 编辑按钮 -->
        <ImageButton
            android:id="@+id/edit_rule"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="编辑"
            android:layout_marginStart="2dp" />

        <!-- 移动按钮 -->
        <ImageButton
            android:id="@+id/move_rule"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/baseline_arrow_downward_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="移动"
            android:layout_marginStart="2dp" />
<!--        baseline_arrow_upward_24-->

        <!-- 导出按钮 -->
        <ImageButton
            android:id="@+id/export_rule"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/baseline_output_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="导出"
            android:layout_marginStart="2dp" />

        <!-- 删除按钮 -->
        <ImageButton
            android:id="@+id/delete_rule"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/baseline_delete_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="删除"
            android:layout_marginStart="2dp" />
    </LinearLayout>
</LinearLayout>