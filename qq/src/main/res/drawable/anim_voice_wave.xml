<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    
    <aapt:attr name="android:drawable">
        <vector
            android:width="20dp"
            android:height="20dp"
            android:viewportWidth="20"
            android:viewportHeight="20">
            
            <!-- 左边的竖条 (矮) - 使用 group 包裹以便动画 -->
            <group android:name="bar_left">
                <path
                    android:name="path_left"
                    android:fillColor="#000000"
                    android:pathData="M4,8 L7,8 L7,12 L4,12 Z"
                    android:strokeWidth="0"/>
            </group>
            
            <!-- 中间的竖条 (高) -->
            <group android:name="bar_middle">
                <path
                    android:name="path_middle"
                    android:fillColor="#000000"
                    android:pathData="M8.5,5 L11.5,5 L11.5,15 L8.5,15 Z"
                    android:strokeWidth="0"/>
            </group>
            
            <!-- 右边的竖条 (中等) -->
            <group android:name="bar_right">
                <path
                    android:name="path_right"
                    android:fillColor="#000000"
                    android:pathData="M13,7 L16,7 L16,13 L13,13 Z"
                    android:strokeWidth="0"/>
            </group>
            
        </vector>
    </aapt:attr>
    
    <!-- 左边竖条的动画 - 8到12再到8 (高度4) -->
    <target android:name="path_left">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="400"
                    android:propertyName="pathData"
                    android:valueFrom="M4,8 L7,8 L7,12 L4,12 Z"
                    android:valueTo="M4,6 L7,6 L7,14 L4,14 Z"
                    android:valueType="pathType"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
            </set>
        </aapt:attr>
    </target>
    
    <!-- 中间竖条的动画 - 5到15再到5 (高度10) -->
    <target android:name="path_middle">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="300"
                    android:propertyName="pathData"
                    android:valueFrom="M8.5,5 L11.5,5 L11.5,15 L8.5,15 Z"
                    android:valueTo="M8.5,3 L11.5,3 L11.5,17 L8.5,17 Z"
                    android:valueType="pathType"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
            </set>
        </aapt:attr>
    </target>
    
    <!-- 右边竖条的动画 - 7到13再到7 (高度6) -->
    <target android:name="path_right">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="500"
                    android:propertyName="pathData"
                    android:valueFrom="M13,7 L16,7 L16,13 L13,13 Z"
                    android:valueTo="M13,5 L16,5 L16,15 L13,15 Z"
                    android:valueType="pathType"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:interpolator="@android:anim/accelerate_decelerate_interpolator"/>
            </set>
        </aapt:attr>
    </target>
    
</animated-vector>