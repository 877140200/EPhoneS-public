<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_rounded">

    <TextView
        android:id="@+id/waimai_detail_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="订单详情"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

    <!-- Waimai Order Details -->
    <LinearLayout
        android:id="@+id/waimai_order_details_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView style="@style/WaimaiDetailTextView" android:text="订单类型：为ta点单" />
        <TextView android:id="@+id/waimai_order_sender" style="@style/WaimaiDetailTextView" tools:text="赠送方：我" />
        <TextView android:id="@+id/waimai_order_recipient" style="@style/WaimaiDetailTextView" tools:text="接收方：AI" />
        <TextView android:id="@+id/waimai_order_product" style="@style/WaimaiDetailTextView" tools:text="商品：奶茶" />
        <TextView android:id="@+id/waimai_order_amount" style="@style/WaimaiDetailTextView" tools:text="金额：¥15.00" />
        <TextView android:id="@+id/waimai_order_greeting" style="@style/WaimaiDetailTextView" tools:text="问候语：请你喝" />
    </LinearLayout>

    <!-- Waimai Request Details -->
    <LinearLayout
        android:id="@+id/waimai_request_details_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="gone">

        <TextView android:id="@+id/waimai_request_product" style="@style/WaimaiDetailTextView" tools:text="商品：奶茶" />
        <TextView android:id="@+id/waimai_request_amount" style="@style/WaimaiDetailTextView" tools:text="金额：¥15.00" />
        <TextView android:id="@+id/waimai_request_status" style="@style/WaimaiDetailTextView" tools:text="状态：等待对方处理" />
    </LinearLayout>

    <!-- Action Buttons for received waimai_request -->
    <LinearLayout
        android:id="@+id/waimai_request_actions_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <Button
            android:id="@+id/waimai_reject_button"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="拒绝" />

        <Button
            android:id="@+id/waimai_accept_button"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="同意" />
    </LinearLayout>

</LinearLayout>