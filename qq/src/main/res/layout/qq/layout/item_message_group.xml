<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 消息组类型和标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/groupTypeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="对话组"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/bg_rounded_gray"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

            <TextView
                android:id="@+id/groupTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="完整对话"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 时间信息 -->
        <TextView
            android:id="@+id/startTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="起始: 2024-01-01 12:00:00"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/endTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="结束: 2024-01-01 12:30:00"
            android:textSize="13sp" />

        <!-- 持续时间和消息数量 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/durationText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="持续: 30分钟"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorSecondary" />

            <TextView
                android:id="@+id/messageCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15条消息"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorSecondary" />

        </LinearLayout>

        <!-- 参与者 -->
        <TextView
            android:id="@+id/participantsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="参与者: 用户, AI"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- 消息内容列表 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="消息内容："
            android:textSize="13sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messagesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>