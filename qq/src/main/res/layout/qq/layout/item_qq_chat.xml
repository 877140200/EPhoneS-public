<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorPrimary">

    <!-- 背景层：包含删除和置顶按钮 -->
    <LinearLayout
        android:id="@+id/buttons_layout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/delete_button"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="?attr/colorError"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="删除"
            android:textColor="?attr/colorOnError"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/pin_button"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="?attr/colorPrimary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="置顶"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 前景层：包含原有的所有联系人信息 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contact_item_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="?attr/colorSurface"
        android:clickable="true"
        android:focusable="true">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageViewAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:src="@tools:sample/avatars" />

        <TextView
            android:id="@+id/textViewCharacterName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            app:layout_constraintBottom_toTopOf="@id/textViewCharacterStatus"
            app:layout_constraintEnd_toStartOf="@+id/textViewLastMessageTime"
            app:layout_constraintStart_toEndOf="@id/imageViewAvatar"
            app:layout_constraintTop_toTopOf="@id/imageViewAvatar"
            tools:text="Initial Character" />

        <TextView
            android:id="@+id/textViewLastMessageTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintBottom_toBottomOf="@id/textViewCharacterName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/textViewCharacterName"
            tools:text="10:45" />

        <TextView
            android:id="@+id/textViewCharacterStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintBottom_toBottomOf="@id/imageViewAvatar"
            app:layout_constraintEnd_toStartOf="@id/textViewNewMessageCount"
            app:layout_constraintStart_toEndOf="@id/imageViewAvatar"
            app:layout_constraintTop_toBottomOf="@id/textViewCharacterName"
            tools:text="Online" />

        <TextView
            android:id="@+id/textViewNewMessageCount"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:background="@drawable/bg_message_count"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@id/textViewCharacterStatus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/textViewCharacterStatus"
            tools:text="1" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>