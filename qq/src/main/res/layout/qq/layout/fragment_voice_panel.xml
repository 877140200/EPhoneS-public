<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:background="?attr/colorSurfaceContainer">

    <!-- 顶部：录音时长显示 (默认不可见但占用空间) -->
    <TextView
        android:id="@+id/voice_timer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0:00"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:letterSpacing="0.05"
        android:visibility="invisible"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"
        tools:text="0:02" />

    <!-- 音量波形显示 -->
    <LinearLayout
        android:id="@+id/voice_waveform_container"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/voice_timer_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <!-- 波形条 - 动态添加 -->
        <View
            android:layout_width="4dp"
            android:layout_height="12dp"
            android:layout_marginHorizontal="2dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.4" />

        <View
            android:layout_width="4dp"
            android:layout_height="20dp"
            android:layout_marginHorizontal="2dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.6" />

        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:layout_marginHorizontal="2dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.8" />

        <View
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="2dp"
            android:background="?attr/colorPrimary" />

        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:layout_marginHorizontal="2dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.8" />

        <View
            android:layout_width="4dp"
            android:layout_height="20dp"
            android:layout_marginHorizontal="2dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.6" />

        <View
            android:layout_width="4dp"
            android:layout_height="12dp"
            android:layout_marginHorizontal="2dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.4" />
    </LinearLayout>

    <!-- 语音识别文本框 (在波形下方) -->
    <EditText
        android:id="@+id/voice_text_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:hint="识别的文字将显示在这里..."
        android:textSize="14sp"
        android:minHeight="38dp"
        android:maxLines="2"
        android:gravity="top|start"
        android:padding="12dp"
        android:background="@drawable/bg_message_input"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?attr/colorOnSurfaceVariant"
        app:layout_constraintTop_toBottomOf="@id/voice_waveform_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 操作按钮行：居中放在输入框和麦克风之间，避免小手机窄屏时被圆形麦克风挤出屏幕。 -->
    <LinearLayout
        android:id="@+id/voice_action_button_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/voice_text_input">

        <!-- 重新识别按钮 (默认隐藏) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/voice_retry_recognize_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:alpha="0"
            android:maxLines="1"
            android:text="重新识别"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- 确认按钮 (默认隐藏) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/voice_confirm_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:alpha="0"
            android:maxLines="1"
            android:text="确认"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 圆形麦克风按钮容器 (居中) -->
    <FrameLayout
        android:id="@+id/voice_button_container"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:layout_constraintTop_toBottomOf="@id/voice_action_button_row"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp">

        <!-- 外层光晕圆圈 (按住时显示) -->
        <View
            android:id="@+id/voice_outer_circle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_voice_outer_circle"
            android:alpha="0"
            android:visibility="invisible" />

        <!-- 主按钮 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/voice_record_button"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            app:cardCornerRadius="50dp"
            app:cardBackgroundColor="?attr/colorPrimary">

            <ImageView
                android:id="@+id/voice_mic_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic_24"
                android:contentDescription="麦克风"
                app:tint="@android:color/white" />

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- 取消区域 (在按钮右边，默认隐藏) -->
    <LinearLayout
        android:id="@+id/voice_cancel_area"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_voice_cancel_area"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/voice_button_container"
        app:layout_constraintBottom_toBottomOf="@id/voice_button_container"
        app:layout_constraintStart_toEndOf="@id/voice_button_container"
        android:layout_marginStart="24dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close_24"
            android:contentDescription="取消"
            app:tint="?attr/colorError" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="取消"
            android:textSize="10sp"
            android:textColor="?attr/colorError"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- 提示文字 -->
    <TextView
        android:id="@+id/voice_hint_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="按住说话"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:alpha="0.7"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>