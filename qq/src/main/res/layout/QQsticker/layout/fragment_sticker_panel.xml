<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_panel_rounded"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
    tools:context=".ui.sticker.StickerPanelFragment">

    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"/>

    <!-- 普通模式不再提供顶部设置/完成入口，长按表情进入管理模式 -->

    <!-- 表情网格 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sticker_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?attr/colorSurface"
        android:padding="8dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="4"
        tools:listitem="@layout/item_sticker" />

    <!-- 底部搜索栏：搜索内嵌在表情面板内，不再使用弹窗 -->
    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="?attr/colorSurface"
        tools:visibility="visible">

        <EditText
            android:id="@+id/search_sticker_edit_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/editTextBackground"
            android:hint="搜索表情"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp" />

        <ImageButton
            android:id="@+id/clear_search_button"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:contentDescription="清空搜索"
            android:src="@drawable/ic_close_24"/>
    </LinearLayout>

    <!-- 管理模式底部操作栏 (初始隐藏)：按钮等宽平分，完成按钮放在删除按钮右侧 -->
    <!-- 按钮较多，统一压缩 minWidth/inset/padding，避免窄屏溢出 -->
    <LinearLayout
        android:id="@+id/management_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:background="?attr/colorSurface"
        android:visibility="gone"
        tools:visibility="visible">

        <Button
            android:id="@+id/select_all_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="全选" />

        <Button
            android:id="@+id/pin_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="置顶" />

        <Button
            android:id="@+id/rename_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="改名" />

        <Button
            android:id="@+id/export_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="导出" />

        <Button
            android:id="@+id/sticker_delete_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="删除" />

        <Button
            android:id="@+id/done_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="4dp"
            android:text="完成" />
    </LinearLayout>

</LinearLayout>