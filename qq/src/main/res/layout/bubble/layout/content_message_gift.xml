<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:minWidth="250dp"
    android:maxWidth="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_transfer_card_sent"
    android:padding="16dp">

    <!-- 礼物图标 -->
    <ImageView
        android:id="@+id/gift_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_gift_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <!-- 礼物标题 -->
    <TextView
        android:id="@+id/gift_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="赠送礼物"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/paw_prints"
        app:layout_constraintStart_toEndOf="@+id/gift_icon"
        app:layout_constraintTop_toTopOf="@+id/gift_icon" />

    <ImageView
        android:id="@+id/paw_prints"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_paw_prints"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white_with_alpha_128" />

    <!-- 礼物图片和信息容器 -->
    <LinearLayout
        android:id="@+id/gift_content_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gift_title">

        <!-- 礼物图片 -->
        <ImageView
            android:id="@+id/gift_image"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_rounded_gray"
            tools:src="@drawable/ic_gift_24" />

        <!-- 礼物信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <!-- 礼物名称 -->
            <TextView
                android:id="@+id/gift_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="精美礼物名称" />

            <!-- 礼物价值 -->
            <TextView
                android:id="@+id/gift_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/white_with_alpha_128"
                android:textSize="14sp"
                tools:text="价值 ¥99.99" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/white_with_alpha_128"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gift_content_layout" />

    <!-- 赠送说明 -->
    <TextView
        android:id="@+id/gift_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="❤️ 送给你的小礼物"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/divider" />

</androidx.constraintlayout.widget.ConstraintLayout>