<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/image_bubble_layout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:longClickable="true"
    android:padding="4dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardElevation="0dp"
        app:cardCornerRadius="12dp">

        <ImageView
            android:id="@+id/message_image_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:maxWidth="280dp"
            android:maxHeight="280dp"
            android:minWidth="50dp"
            android:minHeight="50dp"
            android:scaleType="fitCenter"
            tools:src="@tools:sample/backgrounds/scenic" />
    </com.google.android.material.card.MaterialCardView>

    <ImageButton
        android:id="@+id/zoom_image_button"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_gravity="top|start"
        android:background="@drawable/bg_circle_scrim"
        android:src="@drawable/ic_expand_less_24"
        android:visibility="gone"
        app:tint="?attr/colorOnPrimary"
        tools:visibility="visible" />

    <ImageButton
        android:id="@+id/rewrite_prompt_button"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_circle_scrim"
        android:src="@drawable/ic_edit_24"
        android:visibility="gone"
        app:tint="?attr/colorOnPrimary"
        tools:visibility="visible" />

    <ImageButton
        android:id="@+id/reroll_image_button"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bg_circle_scrim"
        android:src="@drawable/ic_replay_24"
        android:visibility="gone"
        app:tint="?attr/colorOnPrimary"
        tools:visibility="visible" />
</FrameLayout>